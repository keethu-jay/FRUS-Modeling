# Public token from https://account.mapbox.com/access-tokens/ (URL restrictions recommended)
VITE_MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Secret token for local scripts only (npm run upload:tileset) — uploads:write + uploads:read
# Never use VITE_ for sk.* tokens (never bundle secrets into the browser).
# MAPBOX_SECRET_TOKEN=sk.your_secret_token
# MAPBOX_USERNAME=your_mapbox_username

# Topography = Mapbox vector tilesets (eco_topo_nyc_p01 …) — optional username override
# VITE_MAPBOX_TOPO_USERNAME=keethu-j

# Optional: permeability shapefile zip under public/ (parsed in-browser with shpjs)
# VITE_MASK_VECTOR_ZIP=data/mask_vector.zip
# Max zip size (MB) before skipping parse — huge extracts will crash the tab (default 48).
# VITE_MAX_SHAPEFILE_ZIP_MB=48

# Dev: leave as /  |  GitHub Pages project site: /YourRepoName/ (leading + trailing slash)
VITE_BASE_PATH=/

# Optional: curb GeoJSON path under public/ (default data/vectors/curbs.geojson — full LiDAR mesh).
# Use data/vectors/curbs_web.geojson for a smaller decimated build from scripts/clip_curbs_subset.py
# VITE_CURBS_GEOJSON=data/vectors/curbs_web.geojson
